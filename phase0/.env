# HappyHorse API 配置（百炼平台）
# API Key 来源: https://bailian.console.aliyun.com/#/api-key
HAPPYHORSE_API_KEY=sk-ws-H.RYEEIPH.IvKl.MEQCIDl-mkf-ySARvvYE_T2aubgBaj9mUiF87G5WMJFXU-snAiAnOGoTufoyRyGoYFJYVHQf9aYmmP5WjBr9_3Q0k8c1Vg
HAPPYHORSE_BASE_URL=https://dashscope.aliyuncs.com

# API 端点
HAPPYHORSE_T2V_ENDPOINT=/api/v1/services/aigc/video-generation/video-synthesis
HAPPYHORSE_TASK_ENDPOINT=/api/v1/tasks

# 模型名（已验证可用）
HAPPYHORSE_MODEL_T2V=happyhorse-1.0-t2v
HAPPYHORSE_MODEL_I2V=happyhorse-1.0-i2v
HAPPYHORSE_MODEL_R2V=happyhorse-1.0-r2v

# LLM 评分用（DeepSeek / 千问）
LLM_API_KEY=sk-your-key-here
LLM_MODEL=qwen-turbo-latest

# 生成参数
RESOLUTION=720p         # 720p | 1080p (size 参数用 "1280*720" 格式)
SAMPLES_PER_DIM=10      # 每个维度测试次数
DURATION=5.0            # 默认生成时长（秒）
