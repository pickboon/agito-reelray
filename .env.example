# ============================================================
# ReelRay 环境变量模板
# 复制为 .env.local 后填入实际值
# 详见 DEPLOY.md
# ============================================================

# ---- Supabase (认证 & 数据库) ----
# 项目 URL — Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# 匿名公钥 — 客户端认证使用
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 服务端密钥 — 仅在 API Routes / Server Components 中使用，勿暴露到客户端
SUPABASE_SERVICE_ROLE_KEY=

# ---- Stripe (支付) ----
# 服务端密钥 (sk_live_... 或 sk_test_...)
STRIPE_SECRET_KEY=
# Webhook 签名密钥 (whsec_...) — Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=
# 套餐 Price ID (price_...) — Stripe Dashboard → Products
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_STRIPE_STUDIO_PRICE_ID=

# ---- Cloudflare R2 (对象存储) ----
# Cloudflare 账户 ID — Dashboard → Account Home 右侧栏
R2_ACCOUNT_ID=
# S3 兼容访问凭证 — Dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# 存储桶名称
R2_BUCKET_NAME=
# 公开访问 URL (如 https://cdn.reelray.agitoai.com)
R2_PUBLIC_URL=

# ---- HappyHorse / 百炼平台 (视频生成) ----
# API 密钥 — 阿里云百炼平台 → API Key 管理
HAPPYHORSE_API_KEY=
# API 基址，通常无需修改
HAPPYHORSE_BASE_URL=https://dashscope.aliyuncs.com
# 文生视频端点路径
HAPPYHORSE_T2V_ENDPOINT=/api/v1/services/aigc/video-generation/video-synthesis

# ---- DeepSeek (智能助手) ----
# API 密钥 — DeepSeek 开放平台 → API Keys
DEEPSEEK_API_KEY=
# API 基址，通常无需修改
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ---- 应用配置 ----
# 站点公开 URL — 用于 Stripe 回调、Webhook 注册等
NEXT_PUBLIC_SITE_URL=https://reelray.agitoai.com
# 应用 URL — 用于页面跳转和 SEO meta
NEXT_PUBLIC_APP_URL=https://reelray.agitoai.com
# 应用名称 — 用于页面标题和 meta 信息
NEXT_PUBLIC_APP_NAME=ReelRay
